@model RestaurantManager.ViewModels.BasketViewModel
@{
	ViewData["Title"] = "Basket";
}

<script>
    const initialQuantities = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model.BasketItems.ToDictionary(i => i.MenuItemId, i => i.Quantity)
    ));
</script>
<div>
@if (!Model.BasketItems.Any())
{
    <div class="flex flex-col items-center justify-center py-20 text-center">
        <div class="text-6xl mb-4">🛒</div>
        <h2 class="text-lg font-semibold text-gray-700 mb-1">Your basket is empty</h2>
        <p class="text-sm text-gray-400 mb-6">Add some items from the menu to get started.</p>
        <a href="/menu"
           class="bg-orange-500 text-white text-sm font-semibold px-6 py-2.5
                  rounded-full hover:bg-orange-600 active:scale-95 transition-all">
            Browse Menu
        </a>
    </div>
}
else
{
    <h2 class="text-lg font-bold text-gray-800 p-4">Basket</h2>
	@foreach (var item in Model.BasketItems)
	{
        <div class="bg-white rounded-2xl shadow-sm flex justify-between items-center p-4 border-t border-gray-100 first:border-t-0"
                x-data="itemState(@item.MenuItemId)"
                x-init="init()"
                x-show="qty > 0">

            <h3 class="font-semibold text-gray-900 truncate">
                @item.Name <span class="text-gray-500 text-sm">x<span x-text="qty"></span></span>
            </h3>

            <div class="flex items-center space-x-1">
                <button x-on:click="remove()"
                        class="w-8 h-8 flex items-center justify-center text-xl font-medium
                    text-gray-500 hover:text-red-600 active:scale-90 transition-all">
                    −
                </button>
        
                <button x-on:click="add()"
                        class="w-8 h-8 flex items-center justify-center text-xl font-medium
                    text-gray-500 hover:text-green-600 active:scale-90 transition-all">
                    +
                </button>
                        
                <button x-on:click="removeAll()"
                        class="ml-2 w-8 h-8 flex items-center justify-center text-sm font-bold
                    text-gray-400 hover:text-red-700 active:scale-90 transition-all">
                    ✕
                </button>
            </div>
        </div>
	}
    
    <div class="bg-white rounded-2xl shadow-sm p-4 mb-6">
        <form method="post" action="/order/placeorder">
            @Html.AntiForgeryToken()
            <button type="submit"
                    class="w-full bg-orange-500 text-white font-bold py-3 rounded-xl
                hover:bg-orange-600 active:scale-95 transition-all">
                Place Order 🍽️
            </button>
        </form>
    </div>
}
    <div class="bg-white rounded-2xl shadow-sm p-4">
        <details class="group">
            <summary class="flex justify-between items-center cursor-pointer list-none">
                <h2 class="text-lg font-bold text-gray-800">Previous Orders</h2>
                <span class="transition group-open:rotate-180">
                    <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
                </span>
            </summary>

            <div class="mt-4 space-y-3">
                @foreach (var item in Model.PreviousOrderItems)
                {
                    <div class="flex justify-between border-t border-gray-100 pt-3">
                        <h3 class="font-semibold text-gray-900 truncate">
                            @item.Name x<span class="text-gray-500">@item.Quantity</span>
                        </h3>
                    </div>
                }
            </div>
        </details>
        
        <div class="flex flex-row justify-between mt-5">
            <h2 class="text-lg font-bold text-gray-800 mb-3">Total</h2>
            <span class="text-sm font-medium text-green-600">
                @Model.Total.ToString("F2")€
            </span>
        </div>
    </div>
</div>
@section Scripts {
    <script src="~/js/order.js" asp-append-version="true"></script>
}