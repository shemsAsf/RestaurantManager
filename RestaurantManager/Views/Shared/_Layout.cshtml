<!DOCTYPE html>
<html lang="en" x-data="basketState()">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Restaurant</title>
    <script type="importmap"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="~/RestaurantManager.styles.css" asp-append-version="true" />

    @if (ViewData["HasSession"] is true)
    {
        <meta name="table-number" content="@ViewData["TableNumber"]" />
        <meta name="basket-count" content="@ViewData["BasketCount"]" />
    }

</head>
<body>
    <header class="sticky top-0 z-50 bg-white shadow-sm px-4 py-3 flex items-center justify-between">
        <span class="font-bold text-lg">Restaurant Name</span>
            @if (ViewData["HasSession"] is true)
            {
            <a href="/basket" class="relative">
                <img class="h-10" src="/images/basket.svg" alt="Basket">
                <span x-show="basketCount > 0"
                      x-text="basketCount"
                      class="absolute -top-1 -right-1 bg-red-500 text-white text-xs
                    rounded-full w-5 h-5 flex items-center justify-center">
                </span>
            </a>
            }
            
    </header>
    <main class="max-w-2xl mx-auto px-4 py-6">
        @RenderBody()
    </main>

    @if (ViewData["HasSession"] is true)
    {
        <nav class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200
                flex justify-around items-center h-16 z-50">
            <a href="/menu" class="flex flex-col items-center text-xs gap-1
                                @(ViewData["ActiveTab"]?.ToString() == "menu" ? "text-orange-500" : "text-gray-500")">
                <svg .../> Menu
            </a>
            <a href="/basket" class="flex flex-col items-center text-xs gap-1 relative
                                    @(ViewData["ActiveTab"]?.ToString() == "basket" ? "text-orange-500" : "text-gray-500")">
                <svg .../> Basket
                <span x-show="basketCount > 0" x-text="basketCount"
                class="absolute top-0 right-3 bg-red-500 text-white text-xs rounded-full w-4 h-4 flex items-center justify-center">
                </span>
            </a>
            <a href="/order/history" class="flex flex-col items-center text-xs gap-1
                                            @(ViewData["ActiveTab"]?.ToString() == "orders" ? "text-orange-500" : "text-gray-500")">
                <svg .../> Orders
            </a>
        </nav>
    }
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
